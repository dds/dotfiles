[user]
	name = David Smith
	email = davidsmith@acm.org
[alias]
	lola = log --graph --decorate --pretty=oneline --abbrev-commit
	lol = log --graph --decorate --pretty=oneline --abbrev-commit
[core]
	pager = /bin/cat
[hub]
	protocol = ssh
[pull]
	rebase = true
[push]
	default = simple
[status]
	submoduleSummary = true
[init]
	defaultBranch = main
[includeIf "hasconfig:remote.*.url:**fbinfra.net**"]
	path = ~/.gitconfig-fbinfra
[http "https://git.internal.tfbnw.net"]
	sslCert = /var/facebook/credentials/dds/x509/dds.pem
	sslKey = /var/facebook/credentials/dds/x509/dds.pem
[http "https://mononoke-git-lfs.internal.tfbnw.net"]
	sslCert = /var/facebook/credentials/dds/x509/dds.pem
	sslKey = /var/facebook/credentials/dds/x509/dds.pem
[http "https://manifold.c2p.facebook.net"]
	sslCert = /var/facebook/credentials/dds/x509/dds.pem
